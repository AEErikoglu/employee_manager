<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:frontend.ViewModels"
             x:Class="frontend.MainPage"
             x:DataType="viewModels:SignUpViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="Inter" />
            <Setter Property="TextColor" Value="{StaticResource AppSecondaryText}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>

        <Style x:Key="SocialCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource AppSurface}" />
            <Setter Property="Stroke" Value="#3A5278" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource AppSurface}" />
            <Setter Property="Stroke" Value="#37507A" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HeightRequest" Value="54" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid BackgroundColor="{StaticResource AppBackground}"
          Padding="16,20">
        <Grid x:Name="ResponsiveContent"
              WidthRequest="404"
              HeightRequest="760"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="16">
            <Border Grid.Row="0"
                    WidthRequest="72"
                    HeightRequest="72"
                    HorizontalOptions="Center"
                    StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Color="{StaticResource AppAccent}" Offset="0" />
                        <GradientStop Color="{StaticResource ButtonNormal}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource ButtonShadow}"
                            Offset="0,8"
                            Radius="18"
                            Opacity="0.9" />
                </Border.Shadow>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Label Text="A"
                       FontFamily="Inter"
                       TextColor="White"
                       FontSize="30"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <VerticalStackLayout Grid.Row="1"
                                 Spacing="4">
                <Label Text="Create account"
                       FontFamily="Inter"
                       TextColor="{StaticResource AppForeground}"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="Join us - it only takes a minute"
                       Style="{StaticResource SectionLabelStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="2"
                                 Spacing="10">
                <Border Style="{StaticResource SocialCardStyle}">
                    <Grid ColumnDefinitions="28,*"
                          ColumnSpacing="16">
                        <Image Source="apple.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontFamily="Inter"
                               Text="Continue with Apple"
                               TextColor="{StaticResource AppForeground}"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SocialCardStyle}">
                    <Grid ColumnDefinitions="28,*"
                          ColumnSpacing="16">
                        <Image Source="google.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontFamily="Inter"
                               Text="Continue with Google"
                               TextColor="{StaticResource AppForeground}"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SocialCardStyle}">
                    <Grid ColumnDefinitions="28,*"
                          ColumnSpacing="16">
                        <Image Source="microsoft.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontFamily="Inter"
                               Text="Continue with Microsoft"
                               TextColor="{StaticResource AppForeground}"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto,*"
                  ColumnSpacing="12"
                  Margin="0,2,0,0">
                <BoxView HeightRequest="1"
                         VerticalOptions="Center"
                         Color="#39527A" />
                <Label Grid.Column="1"
                       Text="or sign up with email"
                       Style="{StaticResource SectionLabelStyle}" />
                <BoxView Grid.Column="2"
                         HeightRequest="1"
                         VerticalOptions="Center"
                         Color="#39527A" />
            </Grid>

            <VerticalStackLayout Grid.Row="4"
                                 Spacing="10">
                <Border Style="{StaticResource InputCardStyle}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Image Source="email.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               Aspect="AspectFit"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               FontFamily="Inter"
                               Placeholder="Email address"
                               PlaceholderColor="{StaticResource AppSecondaryText}"
                               Text="{Binding EmailAddress}"
                               TextColor="{StaticResource AppForeground}"
                               BackgroundColor="Transparent"
                               Keyboard="Email"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource InputCardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Image Source="lock.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               Aspect="AspectFit"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               FontFamily="Inter"
                               Placeholder="Password"
                               PlaceholderColor="{StaticResource AppSecondaryText}"
                               Text="{Binding Password}"
                               TextColor="{StaticResource AppForeground}"
                               BackgroundColor="Transparent"
                               IsPassword="{Binding IsPasswordHidden}"
                               VerticalOptions="Center" />
                        <Button Grid.Column="2"
                                FontFamily="Inter"
                                Text="{Binding PasswordToggleText}"
                                Clicked="OnTogglePasswordClicked"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource AppSecondaryText}"
                                Padding="4,0"
                                FontSize="13"
                                CornerRadius="0"
                                MinimumHeightRequest="0"
                                MinimumWidthRequest="0" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <Grid Grid.Row="5"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="8"
                  Margin="0,2,0,0">
                <CheckBox IsChecked="{Binding HasAcceptedTerms}"
                          Color="{StaticResource AppAccent}"
                          VerticalOptions="Start" />
                <Label Grid.Column="1"
                       FontFamily="Inter"
                       FontSize="13"
                       TextColor="{StaticResource AppSecondaryText}"
                       VerticalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="I agree to the " />
                            <Span Text="Terms of Service"
                                  TextColor="{StaticResource AppAccent}" />
                            <Span Text=" and " />
                            <Span Text="Privacy Policy"
                                  TextColor="{StaticResource AppAccent}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>

            <VerticalStackLayout Grid.Row="6"
                                 Spacing="12">
                <Button Text="Create account  ->"
                        FontFamily="Inter"
                        IsEnabled="{Binding CanCreateAccount}"
                        BackgroundColor="{Binding CreateAccountButtonColor}"
                        TextColor="{StaticResource AppBackground}"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="18"
                        Padding="18,16">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource ButtonShadow}"
                                Offset="0,10"
                                Radius="24"
                                Opacity="0.65" />
                    </Button.Shadow>
                </Button>

                <Label HorizontalTextAlignment="Center"
                       FontFamily="Inter"
                       FontSize="13">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Already have an account? "
                                  TextColor="{StaticResource AppSecondaryText}" />
                            <Span Text="Sign in"
                                  TextColor="{StaticResource AppAccent}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
